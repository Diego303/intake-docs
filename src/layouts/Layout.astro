---
import { ClientRouter } from 'astro:transitions';
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import '../styles/global.css';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
}

const { lang, title, description } = Astro.props;
const pageTitle = title || t('layout.title', lang);
const pageDesc = description || t('layout.description', lang);
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="description" content={pageDesc} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700;900&family=JetBrains+Mono:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen blueprint-grid">
    <slot />
  </body>
</html>

<style>
  .min-h-screen {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
</style>
