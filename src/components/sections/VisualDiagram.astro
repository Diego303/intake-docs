---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const sources = [
  { icon: 'file', label: 'CLIENT_PDF', color: '#C0392B' },
  { icon: 'markdown', label: 'MARKDOWN', color: '#ededed' },
  { icon: 'text', label: 'TEXTO_LIBRE', color: '#a1a1aa' },
  { icon: 'trello', label: 'JIRA', color: '#60a5fa' },
  { icon: 'slack', label: 'SLACK', color: '#a78bfa' },
  { icon: 'book', label: 'CONFLUENCE', color: '#93c5fd' },
];

const targets = [
  { label: 'CLAUDE_CODE', icon: 'bot' },
  { label: 'CURSOR_IDE', icon: 'terminal' },
  { label: 'ARCHITECT', icon: 'architect', highlight: true, href: 'https://diego303.github.io/architect-docs/' },
  { label: 'COPILOT_CLI', icon: 'terminal' },
  { label: 'CUSTOM_AGENTS', icon: 'cpu' },
  { label: 'DESARROLLO_MANUAL', icon: 'hand' },
];
---

<section class="diagram-section">
  <div class="diagram-frame tech-border tech-shadow">
    <div class="diagram-grid-bg blueprint-grid"></div>

    <!-- Phase headers (desktop) -->
    <div class="phase-headers">
      <div class="phase-header phase-left">{t('diagram.phase1', lang)}</div>
      <div class="phase-header phase-center">{t('diagram.phase2', lang)}</div>
      <div class="phase-header phase-right">{t('diagram.phase3', lang)}</div>
    </div>

    <div class="diagram-content">
      <!-- LEFT: Sources -->
      <div class="diagram-col diagram-col-left">
        <div class="phase-header-mobile">{t('diagram.phase1', lang)}</div>
        {sources.map(src => (
          <div class="source-item tech-border">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={src.color} stroke-width="2">
              {src.icon === 'trello' && <><rect x="3" y="3" width="18" height="18" rx="2" /><rect x="7" y="7" width="3" height="7" /><rect x="14" y="7" width="3" height="5" /></>}
              {src.icon === 'book' && <><path d="M4 19.5A2.5 2.5 0 016.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" /></>}
              {src.icon === 'file' && <><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></>}
              {src.icon === 'slack' && <><path d="M14.5 10c-.83 0-1.5-.67-1.5-1.5v-5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5z" /><path d="M20.5 10H19V8.5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z" /><path d="M9.5 14c.83 0 1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5S8 21.33 8 20.5v-5c0-.83.67-1.5 1.5-1.5z" /><path d="M3.5 14H5v1.5c0 .83-.67 1.5-1.5 1.5S2 16.33 2 15.5 2.67 14 3.5 14z" /></>}
              {src.icon === 'markdown' && <><path d="M3 5h18v14H3z" /><path d="M7 15V9l3 3 3-3v6" /><path d="M18 13l-2-2v4" /></>}
              {src.icon === 'text' && <><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><line x1="10" y1="9" x2="8" y2="9" /></>}
            </svg>
            {src.label}
          </div>
        ))}
      </div>

      <!-- CENTER: Engine box (no SVG here on desktop — SVG is full-width overlay) -->
      <div class="diagram-col diagram-col-center">
        <!-- Mobile arrows (simple) -->
        <div class="mobile-arrow">
          <svg width="24" height="40" viewBox="0 0 24 40" fill="none">
            <line x1="12" y1="0" x2="12" y2="34" stroke="#52525b" stroke-width="2" />
            <polygon points="7,32 12,40 17,32" fill="#52525b" />
          </svg>
        </div>

        <div class="engine-wrapper">
          <div class="engine-box tech-border-white tech-shadow">
            <div class="engine-hatch hatch-pattern-dark"></div>
            <div class="engine-icon tech-border-white tech-shadow-white">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
                <rect x="3" y="3" width="18" height="18" />
              </svg>
            </div>
            <h3 class="engine-title">INTAKE</h3>
          </div>
          <div class="spec-label tech-border-brick tech-shadow-brick">
            {t('diagram.specLabel', lang)}
          </div>
        </div>

        <div class="mobile-arrow">
          <svg width="24" height="40" viewBox="0 0 24 40" fill="none">
            <line x1="12" y1="0" x2="12" y2="34" stroke="#C0392B" stroke-width="2" stroke-dasharray="6 3" />
            <polygon points="7,32 12,40 17,32" fill="#C0392B" />
          </svg>
        </div>
      </div>

      <!-- RIGHT: Targets -->
      <div class="diagram-col diagram-col-right">
        <div class="phase-header-mobile">{t('diagram.phase3', lang)}</div>
        {targets.map(tgt => {
          const Tag = tgt.href ? 'a' : 'div';
          const linkProps = tgt.href ? { href: tgt.href, target: '_blank', rel: 'noopener noreferrer' } : {};
          return (
            <Tag
              class:list={['target-item', 'tech-border', { 'target-highlight': tgt.highlight }]}
              {...linkProps}
            >
              {tgt.label}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                {tgt.icon === 'bot' && <><rect x="3" y="11" width="18" height="10" rx="2" /><circle cx="12" cy="5" r="2" /><path d="M12 7v4" /><line x1="8" y1="16" x2="8" y2="16" /><line x1="16" y1="16" x2="16" y2="16" /></>}
                {tgt.icon === 'terminal' && <><polyline points="4 17 10 11 4 5" /><line x1="12" y1="19" x2="20" y2="19" /></>}
                {tgt.icon === 'cpu' && <><rect x="4" y="4" width="16" height="16" rx="2" /><rect x="9" y="9" width="6" height="6" /><line x1="9" y1="1" x2="9" y2="4" /><line x1="15" y1="1" x2="15" y2="4" /><line x1="9" y1="20" x2="9" y2="23" /><line x1="15" y1="20" x2="15" y2="23" /><line x1="20" y1="9" x2="23" y2="9" /><line x1="20" y1="14" x2="23" y2="14" /><line x1="1" y1="9" x2="4" y2="9" /><line x1="1" y1="14" x2="4" y2="14" /></>}
                {tgt.icon === 'architect' && <polygon points="12,3 22,20 2,20" />}
                {tgt.icon === 'hand' && <><path d="M18 11V6a2 2 0 00-4 0v5" /><path d="M14 10V4a2 2 0 00-4 0v6" /><path d="M10 10.5V6a2 2 0 00-4 0v8" /><path d="M18 11a2 2 0 014 0v5a8 8 0 01-8 8H9a8 8 0 01-3-1" /></>}
              </svg>
            </Tag>
          );
        })}
      </div>

      <!-- Desktop-only SVG overlay spanning full diagram width -->
      <svg class="wiring-svg" preserveAspectRatio="none" aria-hidden="true">
        <!-- Lines are drawn via JS to match actual element positions -->
      </svg>
    </div>
  </div>
</section>

<script>
  function drawWiring() {
    const svg = document.querySelector('.wiring-svg') as SVGSVGElement | null;
    if (!svg) return;

    const container = svg.parentElement;
    if (!container) return;

    // Check if desktop layout (SVG is visible)
    if (getComputedStyle(svg).display === 'none') return;

    const containerRect = container.getBoundingClientRect();

    // Get all source and target items
    const sourceItems = container.querySelectorAll('.diagram-col-left .source-item');
    const targetItems = container.querySelectorAll('.diagram-col-right .target-item');
    const engineBox = container.querySelector('.engine-box');

    if (!engineBox || sourceItems.length === 0 || targetItems.length === 0) return;

    const engineRect = engineBox.getBoundingClientRect();

    // Relative positions within the container
    const engineLeftX = engineRect.left - containerRect.left;
    const engineRightX = engineRect.right - containerRect.left;
    const engineCenterY = engineRect.top + engineRect.height / 2 - containerRect.top;

    // Set SVG viewBox to match container pixel size
    const w = containerRect.width;
    const h = containerRect.height;
    svg.setAttribute('viewBox', `0 0 ${w} ${h}`);

    let paths = '';

    // === LEFT SIDE: Sources → bus → INTAKE ===
    const sourceYs: number[] = [];
    sourceItems.forEach(item => {
      const rect = item.getBoundingClientRect();
      const rightX = rect.right - containerRect.left;
      const centerY = rect.top + rect.height / 2 - containerRect.top;
      sourceYs.push(centerY);

      // Horizontal line from source right edge to the bus
      const busX = engineLeftX - 40;
      paths += `<line x1="${rightX}" y1="${centerY}" x2="${busX}" y2="${centerY}" stroke="#52525b" stroke-width="2" />`;
    });

    // Vertical bus line connecting all source lines
    const busLeftX = engineLeftX - 40;
    const minSourceY = Math.min(...sourceYs);
    const maxSourceY = Math.max(...sourceYs);
    paths += `<line x1="${busLeftX}" y1="${minSourceY}" x2="${busLeftX}" y2="${maxSourceY}" stroke="#52525b" stroke-width="2" />`;

    // Single line from bus midpoint to engine left edge
    paths += `<line x1="${busLeftX}" y1="${engineCenterY}" x2="${engineLeftX}" y2="${engineCenterY}" stroke="#52525b" stroke-width="2" />`;

    // Arrow pointing into engine
    paths += `<polygon points="${engineLeftX - 2},${engineCenterY - 5} ${engineLeftX + 8},${engineCenterY} ${engineLeftX - 2},${engineCenterY + 5}" fill="#52525b" />`;

    // === RIGHT SIDE: INTAKE → bus → Targets ===
    const targetYs: number[] = [];
    targetItems.forEach(item => {
      const rect = item.getBoundingClientRect();
      const leftX = rect.left - containerRect.left;
      const centerY = rect.top + rect.height / 2 - containerRect.top;
      targetYs.push(centerY);

      // Horizontal dashed line from bus to target left edge
      const busRX = engineRightX + 40;
      paths += `<line x1="${busRX}" y1="${centerY}" x2="${leftX}" y2="${centerY}" stroke="#C0392B" stroke-width="2" stroke-dasharray="6 3" />`;

      // Arrow at target (pointing right into target)
      paths += `<polygon points="${leftX - 8},${centerY - 5} ${leftX},${centerY} ${leftX - 8},${centerY + 5}" fill="#C0392B" />`;
    });

    // Vertical bus on right
    const busRightX = engineRightX + 40;
    const minTargetY = Math.min(...targetYs);
    const maxTargetY = Math.max(...targetYs);
    paths += `<line x1="${busRightX}" y1="${minTargetY}" x2="${busRightX}" y2="${maxTargetY}" stroke="#C0392B" stroke-width="2" />`;

    // Single dashed line from engine right edge to right bus
    paths += `<line x1="${engineRightX}" y1="${engineCenterY}" x2="${busRightX}" y2="${engineCenterY}" stroke="#C0392B" stroke-width="2" stroke-dasharray="6 3" />`;

    // Arrow leaving engine
    paths += `<polygon points="${engineRightX + 2},${engineCenterY - 5} ${engineRightX + 12},${engineCenterY} ${engineRightX + 2},${engineCenterY + 5}" fill="#C0392B" />`;

    svg.innerHTML = paths;
  }

  function initDiagram() {
    // Small delay to ensure layout is painted
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        drawWiring();
      });
    });
  }

  document.addEventListener('astro:page-load', initDiagram);
  window.addEventListener('resize', drawWiring);
</script>

<style>
  .diagram-section {
    padding: 0 1.5rem 5rem;
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .diagram-frame {
    background: var(--blueprint-paper);
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }

  .diagram-grid-bg {
    position: absolute;
    inset: 0;
    opacity: 0.3;
    pointer-events: none;
  }

  /* Phase headers */
  .phase-headers {
    display: none;
  }

  .phase-header {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #a1a1aa;
  }

  .phase-header-mobile {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #a1a1aa;
    text-align: center;
    border-bottom: 2px solid #3f3f46;
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
  }

  /* Layout */
  .diagram-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: relative;
    z-index: 1;
  }

  .diagram-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
  }

  /* SVG wiring hidden on mobile */
  .wiring-svg {
    display: none;
  }

  /* Mobile arrows */
  .mobile-arrow {
    display: flex;
    justify-content: center;
    padding: 0.25rem 0;
  }

  /* Source and target items */
  .source-item,
  .target-item {
    background: #111;
    padding: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    font-weight: 700;
    color: #d4d4d8;
    position: relative;
    z-index: 2;
    cursor: crosshair;
    transition: border-color 0.15s, color 0.15s;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  .source-item:hover {
    border-color: white;
    color: white;
  }

  .target-item {
    justify-content: flex-end;
  }

  .target-item:hover {
    border-color: var(--brick);
    color: var(--brick);
  }

  .target-highlight {
    background: white;
    color: black;
    border-color: var(--ink-white);
    text-decoration: none;
  }

  .target-highlight:hover {
    color: black;
    border-color: var(--ink-white);
    cursor: pointer;
  }

  /* Engine */
  .engine-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .engine-box {
    background: var(--blueprint-bg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    max-width: 280px;
    margin: 0 auto;
  }

  .engine-hatch {
    position: absolute;
    inset: 0;
    opacity: 0.5;
  }

  .engine-icon {
    background: #111;
    width: 4rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .engine-title {
    font-size: 1.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: white;
    position: relative;
    z-index: 1;
  }

  /* SPEC.YAML label */
  .spec-label {
    background: var(--blueprint-bg);
    color: var(--brick);
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    text-align: center;
    width: fit-content;
    margin: 1rem auto 0;
    position: relative;
    z-index: 10;
  }

  @media (max-width: 480px) {
    .diagram-frame {
      padding: 1rem;
    }

    .source-item,
    .target-item {
      font-size: 0.7rem;
      padding: 0.5rem;
      gap: 0.5rem;
    }

    .source-item svg,
    .target-item svg {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
    }

    .engine-title {
      font-size: 1.25rem;
    }

    .engine-box {
      padding: 1rem;
    }

    .spec-label {
      font-size: 0.65rem;
    }
  }

  /* ── Desktop layout ── */
  @media (min-width: 768px) {
    .diagram-frame {
      padding: 2rem 3rem;
    }

    .phase-headers {
      display: flex;
      justify-content: space-between;
      width: 100%;
      margin-bottom: 2.5rem;
      border-bottom: 2px solid #3f3f46;
      padding-bottom: 1rem;
    }

    .phase-left {
      width: 220px;
      padding-left: 0.5rem;
      border-left: 4px solid #52525b;
    }

    .phase-center {
      flex: 1;
      text-align: center;
      color: white;
      font-weight: 900;
    }

    .phase-right {
      width: 220px;
      text-align: right;
      padding-right: 0.5rem;
      border-right: 4px solid var(--brick);
    }

    .phase-header-mobile {
      display: none;
    }

    .mobile-arrow {
      display: none;
    }

    .diagram-content {
      flex-direction: row;
      align-items: stretch;
      justify-content: space-between;
      gap: 0;
    }

    .diagram-col-left,
    .diagram-col-right {
      width: 220px;
      flex-shrink: 0;
      justify-content: space-between;
    }

    .diagram-col-center {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      padding: 0;
    }

    /* Show the SVG wiring overlay on desktop */
    .wiring-svg {
      display: block;
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
      overflow: visible;
      pointer-events: none;
    }

    /* Engine on top of wiring */
    .engine-wrapper {
      position: relative;
      z-index: 5;
    }
  }
</style>
