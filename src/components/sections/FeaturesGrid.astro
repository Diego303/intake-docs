---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="como-funciona" class="features-section">
  <div class="features-header">
    <h2 class="features-title">{t('features.title', lang)}</h2>
    <div class="features-decor">{t('features.decorSlash', lang)}</div>
  </div>

  <div class="features-grid">
    <!-- Feature 1: Ingesta Universal -->
    <div class="feature-card tech-border tech-shadow">
      <div class="feature-icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="2" width="20" height="20" /><line x1="2" y1="8" x2="22" y2="8" /><line x1="2" y1="14" x2="22" y2="14" /><line x1="8" y1="2" x2="8" y2="22" />
        </svg>
      </div>
      <h3 class="feature-title">{t('features.feat1Title', lang)}</h3>
      <p class="feature-desc">{t('features.feat1Desc', lang)}</p>
    </div>

    <!-- Feature 2: Agnóstico de Agentes -->
    <div class="feature-card tech-border tech-shadow">
      <div class="feature-icon feature-icon-brick">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="4" y="4" width="16" height="16" rx="2" /><rect x="9" y="9" width="6" height="6" /><line x1="9" y1="1" x2="9" y2="4" /><line x1="15" y1="1" x2="15" y2="4" /><line x1="9" y1="20" x2="9" y2="23" /><line x1="15" y1="20" x2="15" y2="23" /><line x1="20" y1="9" x2="23" y2="9" /><line x1="20" y1="14" x2="23" y2="14" /><line x1="1" y1="9" x2="4" y2="9" /><line x1="1" y1="14" x2="4" y2="14" />
        </svg>
      </div>
      <h3 class="feature-title">{t('features.feat2Title', lang)}</h3>
      <p class="feature-desc">{t('features.feat2Desc', lang)}</p>
    </div>

    <!-- Feature 3: Verificación 360° -->
    <div class="feature-card tech-border tech-shadow">
      <div class="feature-icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="18" height="18" /><polyline points="9 11 12 14 22 4" />
        </svg>
      </div>
      <h3 class="feature-title">{t('features.feat3Title', lang)}</h3>
      <p class="feature-desc">{t('features.feat3Desc', lang)}</p>
    </div>

    <!-- Feature 4: Detección de Conflictos (wide) -->
    <div class="feature-card feature-card-wide tech-border-brick tech-shadow-brick">
      <div class="feature-icon feature-icon-brick">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="2" width="20" height="20" /><line x1="2" y1="12" x2="22" y2="12" /><line x1="12" y1="2" x2="12" y2="22" /><circle cx="7" cy="7" r="1" fill="currentColor" /><circle cx="17" cy="17" r="1" fill="currentColor" />
        </svg>
      </div>
      <h3 class="feature-title feature-title-brick">{t('features.feat4Title', lang)}</h3>
      <p class="feature-desc feature-desc-brick">{t('features.feat4Desc', lang)}</p>
    </div>

    <!-- Feature 5: Pipeline de 5 Fases -->
    <div class="feature-card tech-border tech-shadow">
      <div class="feature-icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="8" y1="6" x2="21" y2="6" /><line x1="8" y1="12" x2="21" y2="12" /><line x1="8" y1="18" x2="21" y2="18" /><line x1="3" y1="6" x2="3.01" y2="6" /><line x1="3" y1="12" x2="3.01" y2="12" /><line x1="3" y1="18" x2="3.01" y2="18" />
        </svg>
      </div>
      <h3 class="feature-title">{t('features.feat5Title', lang)}</h3>
      <p class="feature-desc">{t('features.feat5Desc', lang)}</p>
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 6rem 1.5rem;
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
  }

  .features-header {
    margin-bottom: 4rem;
    border-bottom: 4px solid #3f3f46;
    padding-bottom: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .features-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    color: white;
  }

  .features-decor {
    display: none;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--brick);
  }

  .features-grid {
    display: grid;
    gap: 2rem;
  }

  .feature-card {
    background: var(--blueprint-paper);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    transition: transform 0.15s;
  }

  .feature-card:hover {
    transform: translateY(-4px);
  }

  .feature-card-wide {
    background: #111;
  }

  .feature-icon {
    background: #111;
    width: 3.5rem;
    height: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    color: white;
    border: 1px solid #52525b;
  }

  .feature-icon-brick {
    background: var(--brick);
    border-color: white;
  }

  .feature-title {
    font-size: 1.5rem;
    font-weight: 900;
    text-transform: uppercase;
    color: white;
    margin-bottom: 0.75rem;
  }

  .feature-title-brick {
    color: var(--brick);
  }

  .feature-desc {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    font-weight: 500;
    line-height: 1.7;
    color: #a1a1aa;
    flex-grow: 1;
    border-top: 1px dashed #52525b;
    padding-top: 1rem;
  }

  .feature-desc-brick {
    border-color: var(--brick);
    color: #d4d4d8;
  }

  @media (min-width: 768px) {
    .features-decor {
      display: block;
    }

    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .feature-card-wide {
      grid-column: span 2;
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .feature-card-wide {
      grid-column: span 2;
    }
  }
</style>
