---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="metaphor-section">
  <div class="metaphor-box tech-border">
    <div class="metaphor-label">{t('metaphor.noteLabel', lang)}</div>

    <svg class="quote-icon" width="48" height="48" viewBox="0 0 24 24" fill="#3f3f46" stroke="none">
      <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1zm12 0c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z" />
    </svg>

    <blockquote class="metaphor-quote">
      {t('metaphor.quote', lang)}<br />
      <span class="quote-highlight">{t('metaphor.quoteHighlight', lang)}</span>
    </blockquote>

    <p class="metaphor-conclusion">{t('metaphor.conclusion', lang)}</p>
  </div>
</section>

<style>
  .metaphor-section {
    padding: 3rem 1.5rem;
    max-width: 960px;
    margin: 0 auto;
    width: 100%;
  }

  .metaphor-box {
    background: var(--blueprint-paper);
    padding: 2rem;
    position: relative;
  }

  .metaphor-label {
    position: absolute;
    top: -1rem;
    left: -1rem;
    background: var(--brick);
    color: white;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.75rem;
    border: 1px solid white;
  }

  .quote-icon {
    margin-bottom: 1.5rem;
  }

  .metaphor-quote {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1.3;
    border-left: 4px solid #52525b;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: white;
  }

  .quote-highlight {
    color: var(--brick);
  }

  .metaphor-conclusion {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 1.1rem;
    color: #a1a1aa;
  }

  @media (min-width: 768px) {
    .metaphor-box {
      padding: 3rem;
    }
  }
</style>
