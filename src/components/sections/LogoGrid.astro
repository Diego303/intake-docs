---
const integrations = [
  { label: 'Jira', icon: 'trello' },
  { label: 'Confluence', icon: 'book' },
  { label: 'Documentos', icon: 'file', highlight: true },
  { label: 'Slack', icon: 'slack' },
  { label: 'Figma', icon: 'figma' },
  { label: 'Markdown', icon: 'github' },
];
---

<section class="logo-grid-section">
  <div class="logo-grid">
    {integrations.map(item => (
      <div class:list={['logo-item', { 'logo-highlight': item.highlight }]}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          {item.icon === 'trello' && <><rect x="3" y="3" width="18" height="18" rx="2" /><rect x="7" y="7" width="3" height="7" /><rect x="14" y="7" width="3" height="5" /></>}
          {item.icon === 'book' && <><path d="M4 19.5A2.5 2.5 0 016.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" /></>}
          {item.icon === 'file' && <><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /></>}
          {item.icon === 'slack' && <><path d="M14.5 10c-.83 0-1.5-.67-1.5-1.5v-5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5z" /><path d="M20.5 10H19V8.5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z" /></>}
          {item.icon === 'figma' && <><path d="M5 5.5A3.5 3.5 0 018.5 2H12v7H8.5A3.5 3.5 0 015 5.5z" /><path d="M12 2h3.5a3.5 3.5 0 010 7H12V2z" /><path d="M5 12a3.5 3.5 0 013.5-3.5H12v7H8.5A3.5 3.5 0 015 12z" /></>}
          {item.icon === 'github' && <><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22" /></>}
        </svg>
        {item.label}
      </div>
    ))}
  </div>
</section>

<style>
  .logo-grid-section {
    border-top: 2px solid #3f3f46;
    border-bottom: 2px solid #3f3f46;
    background: var(--blueprint-paper);
  }

  .logo-grid {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
  }

  .logo-item {
    flex: 1 1 50%;
    padding: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #a1a1aa;
    border-bottom: 2px solid #3f3f46;
    transition: background-color 0.15s, color 0.15s;
    min-width: 0;
    text-align: center;
  }

  .logo-item:hover {
    background: #27272a;
    color: white;
  }

  .logo-highlight {
    background: var(--brick);
    color: white;
  }

  .logo-highlight:hover {
    background: var(--brick);
    color: white;
  }

  @media (min-width: 480px) {
    .logo-item {
      flex: 1 1 33.33%;
      font-size: 0.8rem;
      padding: 1.25rem;
    }
  }

  @media (min-width: 768px) {
    .logo-item {
      flex: 1;
      border-bottom: none;
      border-right: 2px solid #3f3f46;
      font-size: 0.85rem;
      padding: 1.5rem;
      letter-spacing: 0.1em;
    }

    .logo-item:last-child {
      border-right: none;
    }
  }
</style>
