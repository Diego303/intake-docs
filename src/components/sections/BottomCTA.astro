---
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const base = import.meta.env.BASE_URL;
const docsPath = lang === 'en' ? `${base}en/docs/` : `${base}docs/`;
const repoUrl = 'https://github.com/Diego303/intake-cli';
---

<section class="cta-section">
  <div class="cta-box hatch-pattern-dark">
    <div class="cta-badge">{t('cta.badge', lang)}</div>

    <h2 class="cta-title tech-border-white">{t('cta.title', lang)}</h2>
    <br />
    <p class="cta-subtitle">{t('cta.subtitle', lang)}</p>

    <div class="cta-actions">
      <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="btn-brick tech-border-brick tech-shadow-brick tech-button-brick">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22" />
        </svg>
        {t('cta.btnRepo', lang)}
      </a>
      <a href={docsPath} class="btn-white tech-border-white tech-shadow tech-button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" />
        </svg>
        {t('cta.btnDocs', lang)}
      </a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 6rem 1.5rem;
    max-width: 56rem;
    margin: 0 auto;
    text-align: center;
    width: 100%;
  }

  .cta-box {
    border: 2px solid #3f3f46;
    padding: 3rem 2rem;
    background: var(--blueprint-paper);
    position: relative;
  }

  .cta-badge {
    position: absolute;
    top: -1.5rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--brick);
    color: white;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.5rem 1.5rem;
    border: 1px solid white;
    white-space: nowrap;
  }

  .cta-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    color: white;
    background: var(--blueprint-bg);
    display: inline-block;
    padding: 0.25rem 1rem;
  }

  .cta-subtitle {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 1.1rem;
    color: #d4d4d8;
    background: #111;
    display: inline-block;
    padding: 0.5rem 1rem;
    border: 1px solid #52525b;
    margin-bottom: 2.5rem;
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    justify-content: center;
  }

  .btn-brick,
  .btn-white {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 1rem 2rem;
    font-size: 1rem;
    text-decoration: none;
    cursor: pointer;
  }

  .btn-brick {
    background: var(--brick);
    color: white;
  }

  .btn-white {
    background: white;
    color: black;
  }

  @media (min-width: 640px) {
    .cta-actions {
      flex-direction: row;
    }
  }
</style>
