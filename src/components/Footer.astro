---
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-left">
      <span class="footer-copyright">{t('footer.copyright', lang)}</span>
      <span class="footer-separator">|</span>
      <a
        href="https://diego303.github.io/oss-ecosystem-project/"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-oss"
      >
        {t('footer.oss', lang)}
      </a>
    </div>

    <div class="footer-right">
      <span class="footer-made">{t('footer.madeWith', lang)}</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 2px solid #27272a;
    background: var(--blueprint-bg);
    color: #a1a1aa;
    padding: 2rem 1.5rem;
    margin-top: auto;
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    text-align: center;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-copyright {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    color: #71717a;
  }

  .footer-separator {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: #3f3f46;
  }

  .footer-oss {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: #71717a;
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0s;
  }

  .footer-oss:hover {
    color: var(--ink-white, #ededed);
  }

  .footer-right {
    display: flex;
    align-items: center;
  }

  .footer-made {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    color: #52525b;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (min-width: 768px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
    }

    .footer-left {
      justify-content: flex-start;
    }
  }
</style>
