---

<div class="prose">
  <slot />
</div>

<style>
  .prose {
    max-width: 48rem;
    color: #d4d4d8;
    line-height: 1.7;
  }

  /* Headings */
  .prose :global(h1) {
    font-size: 2.25rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    color: white;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--zinc-border);
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: white;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--zinc-border);
  }

  .prose :global(h3) {
    font-size: 1.15rem;
    font-weight: 700;
    color: white;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  /* Paragraphs */
  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  /* Links */
  .prose :global(a) {
    color: var(--brick);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color 0.15s;
  }

  .prose :global(a:hover) {
    color: white;
  }

  /* Lists */
  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(li::marker) {
    color: var(--zinc-border);
  }

  /* Code inline */
  .prose :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85em;
    background: #18181b;
    color: var(--brick);
    padding: 0.125rem 0.375rem;
    border: 1px solid #27272a;
  }

  /* Code blocks */
  .prose :global(pre) {
    background: #0a0a0a;
    border: 2px solid var(--zinc-border);
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    overflow-x: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: #d4d4d8;
    font-size: inherit;
  }

  /* Tables */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .prose :global(thead) {
    text-align: left;
  }

  .prose :global(th) {
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    color: white;
    padding: 0.75rem;
    border-bottom: 2px solid var(--zinc-border);
    font-family: 'JetBrains Mono', monospace;
  }

  .prose :global(td) {
    padding: 0.75rem;
    border-bottom: 1px solid #27272a;
    color: #a1a1aa;
  }

  /* Blockquote */
  .prose :global(blockquote) {
    border-left: 4px solid var(--brick);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #a1a1aa;
    font-style: normal;
  }

  /* Horizontal rule */
  .prose :global(hr) {
    border: none;
    border-top: 2px solid var(--zinc-border);
    margin: 2rem 0;
  }

  /* Strong */
  .prose :global(strong) {
    color: white;
    font-weight: 700;
  }
</style>
