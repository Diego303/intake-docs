---
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  headings: { depth: number; slug: string; text: string }[];
  title: string;
  versionLabel: string;
  backLink: string;
  lang: Lang;
}

const { headings, title, versionLabel, backLink, lang } = Astro.props;
const tocHeadings = headings.filter(h => h.depth <= 3);
---

<aside class="docs-sidebar" id="docs-sidebar">
  <div class="sidebar-header">
    <a href={backLink} class="sidebar-back">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" />
      </svg>
      {t('sidebar.backToDocs', lang)}
    </a>
    <div class="sidebar-version">{versionLabel}</div>
  </div>

  <div class="sidebar-title">{title}</div>

  <nav class="sidebar-toc" aria-label={t('sidebar.index', lang)}>
    <div class="toc-label">{t('sidebar.index', lang)}</div>
    <ul class="toc-list">
      {tocHeadings.map(h => (
        <li class:list={['toc-item', `toc-depth-${h.depth}`]}>
          <a href={`#${h.slug}`} class="toc-link" data-heading={h.slug}>
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<script>
  document.addEventListener('astro:page-load', () => {
    const headings = document.querySelectorAll('.docs-content h1[id], .docs-content h2[id], .docs-content h3[id]');
    const links = document.querySelectorAll('.toc-link');

    if (!headings.length || !links.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            links.forEach(l => l.classList.remove('toc-active'));
            const active = document.querySelector(`.toc-link[data-heading="${entry.target.id}"]`);
            if (active) active.classList.add('toc-active');
          }
        });
      },
      { rootMargin: '-80px 0px -60% 0px' }
    );

    headings.forEach(h => observer.observe(h));
  });
</script>

<style>
  .docs-sidebar {
    position: sticky;
    top: 5rem;
    height: calc(100vh - 5rem);
    overflow-y: auto;
    padding: 1.5rem;
    border-right: 2px solid var(--zinc-border);
    background: var(--blueprint-paper);
    display: none;
    flex-direction: column;
    width: 280px;
    flex-shrink: 0;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--zinc-border);
  }

  .sidebar-back {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #a1a1aa;
    text-decoration: none;
    transition: color 0.15s;
  }

  .sidebar-back:hover {
    color: white;
  }

  .sidebar-version {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--brick);
    border: 1px solid var(--brick);
    padding: 0.125rem 0.5rem;
  }

  .sidebar-title {
    font-weight: 900;
    font-size: 1.25rem;
    text-transform: uppercase;
    color: white;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .toc-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #71717a;
    margin-bottom: 0.75rem;
  }

  .toc-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .toc-link {
    display: block;
    font-size: 0.85rem;
    color: #a1a1aa;
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-left: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }

  .toc-link:hover {
    color: white;
  }

  .toc-link.toc-active {
    color: white;
    border-left-color: var(--brick);
  }

  .toc-depth-2 {
    padding-left: 0;
  }

  .toc-depth-3 {
    padding-left: 1rem;
  }

  .toc-depth-3 .toc-link {
    font-size: 0.8rem;
  }

  @media (min-width: 1024px) {
    .docs-sidebar {
      display: flex;
    }
  }
</style>
