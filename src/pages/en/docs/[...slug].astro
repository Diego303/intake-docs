---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import DocsSidebar from '../../../components/DocsSidebar.astro';
import Prose from '../../../components/Prose.astro';
import { VERSIONS, getVersionFromSlug } from '../../../config/versions';

export async function getStaticPaths() {
  const docs = await getCollection('docs-en');
  return docs.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const lang = 'en';
const base = import.meta.env.BASE_URL;
const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const version = getVersionFromSlug(entry.id);
const versionConfig = VERSIONS.find(v => v.id === version);
---

<Layout lang={lang} title={`${entry.data.title} — intake docs`}>
  <Navbar lang={lang} />
  <div class="docs-layout">
    <DocsSidebar
      headings={headings}
      title={entry.data.title || ''}
      versionLabel={versionConfig?.label || version}
      backLink={`${base}en/docs/`}
      lang={lang}
    />
    <main class="docs-content">
      <Prose>
        <Content />
      </Prose>
    </main>
  </div>
</Layout>

<style>
  .docs-layout {
    display: flex;
    margin-top: 4rem;
    min-height: calc(100vh - 4rem);
  }

  .docs-content {
    flex: 1;
    padding: 2rem 1.5rem 4rem;
    max-width: 100%;
    overflow-x: hidden;
    background: var(--blueprint-paper);
    min-width: 0;
  }

  @media (max-width: 480px) {
    .docs-content {
      padding: 1.5rem 1rem 3rem;
    }
  }

  @media (min-width: 1024px) {
    .docs-content {
      padding: 3rem 4rem 4rem;
    }
  }
</style>
