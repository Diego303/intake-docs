---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import VersionSelector from '../../components/VersionSelector.astro';
import { t } from '../../i18n/utils';
import { VERSIONS, getVersionFromSlug } from '../../config/versions';

const lang = 'es';
const base = import.meta.env.BASE_URL;
const allDocs = await getCollection('docs');
const sortedDocs = allDocs.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Layout lang={lang} title={`${t('docsHub.title', lang)} — intake`}>
  <Navbar lang={lang} />

  <main class="docs-hub">
    <div class="docs-hub-header">
      <div class="docs-hub-text">
        <h1 class="docs-hub-title">{t('docsHub.title', lang)}</h1>
        <p class="docs-hub-subtitle">{t('docsHub.subtitle', lang)}</p>
      </div>

      <div class="docs-hub-controls">
        <div class="search-box">
          <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
          <input
            type="text"
            id="docs-search"
            class="search-input"
            placeholder={t('docsHub.searchPlaceholder', lang)}
            autocomplete="off"
          />
        </div>
        <VersionSelector versions={VERSIONS} lang={lang} />
      </div>
    </div>

    <div class="docs-grid" id="docs-grid">
      {sortedDocs.map(doc => {
        const version = getVersionFromSlug(doc.id);
        const versionConfig = VERSIONS.find(v => v.id === version);
        return (
          <a
            href={`${base}docs/${doc.id.replace(/\.mdx?$/, '')}/`}
            class="doc-card tech-border tech-shadow"
            data-version={version}
            data-title={doc.data.title?.toLowerCase() || ''}
            data-desc={doc.data.description?.toLowerCase() || ''}
          >
            {doc.data.icon && (
              <div class="doc-card-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d={doc.data.icon} />
                </svg>
              </div>
            )}
            <div class="doc-card-content">
              <div class="doc-card-meta">
                <span class="doc-card-version">{versionConfig?.label || version}</span>
              </div>
              <h2 class="doc-card-title">{doc.data.title}</h2>
              <p class="doc-card-desc">{doc.data.description}</p>
            </div>
          </a>
        );
      })}
    </div>

    <p class="no-results" id="no-results">{t('docsHub.noResults', lang)}</p>
  </main>

  <Footer lang={lang} />
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const search = document.getElementById('docs-search') as HTMLInputElement;
    const grid = document.getElementById('docs-grid');
    const cards = grid?.querySelectorAll('.doc-card') as NodeListOf<HTMLElement>;
    const noResults = document.getElementById('no-results');
    const versionSelect = document.getElementById('version-selector') as HTMLSelectElement;

    if (!search || !grid || !cards || !versionSelect) return;

    function filterCards() {
      const query = search.value.toLowerCase().trim();
      const version = versionSelect.value;
      let visible = 0;

      cards.forEach(card => {
        const title = card.dataset.title || '';
        const desc = card.dataset.desc || '';
        const cardVersion = card.dataset.version || '';

        const matchesSearch = !query || title.includes(query) || desc.includes(query);
        const matchesVersion = cardVersion === version;

        if (matchesSearch && matchesVersion) {
          card.style.display = '';
          visible++;
        } else {
          card.style.display = 'none';
        }
      });

      if (noResults) {
        noResults.style.display = visible === 0 ? 'block' : 'none';
      }
    }

    search.addEventListener('input', filterCards);
    versionSelect.addEventListener('change', filterCards);

    // Filter on load to show only the default selected version
    filterCards();
  });
</script>

<style>
  .docs-hub {
    padding: 6rem 1.5rem 4rem;
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
  }

  .docs-hub-header {
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .docs-hub-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    color: white;
    margin-bottom: 0.5rem;
  }

  .docs-hub-subtitle {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    font-weight: 500;
    color: #a1a1aa;
  }

  .docs-hub-controls {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .search-box {
    position: relative;
    flex: 1;
  }

  .search-icon {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: #71717a;
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    background: var(--blueprint-bg);
    color: var(--ink-white);
    border: 2px solid var(--zinc-border);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.625rem 0.75rem 0.625rem 2.5rem;
    transition: border-color 0s;
  }

  .search-input::placeholder {
    color: #52525b;
  }

  .search-input:focus {
    outline: none;
    border-color: var(--ink-white);
  }

  .docs-grid {
    display: grid;
    gap: 1.5rem;
  }

  .doc-card {
    background: var(--blueprint-paper);
    padding: 1.5rem;
    display: flex;
    gap: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s;
    align-items: flex-start;
  }

  .doc-card:hover {
    transform: translateY(-3px);
    border-color: var(--ink-white);
  }

  .doc-card-icon {
    background: #111;
    width: 3.5rem;
    height: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: white;
    border: 1px solid #52525b;
  }

  .doc-card-content {
    flex: 1;
    min-width: 0;
  }

  .doc-card-meta {
    margin-bottom: 0.5rem;
  }

  .doc-card-version {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--brick);
    border: 1px solid var(--brick);
    padding: 0.125rem 0.5rem;
    text-transform: uppercase;
  }

  .doc-card-title {
    font-size: 1.25rem;
    font-weight: 900;
    text-transform: uppercase;
    color: white;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .doc-card-desc {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    font-weight: 500;
    color: #a1a1aa;
    line-height: 1.5;
  }

  .no-results {
    display: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    color: #71717a;
    text-align: center;
    padding: 3rem 0;
    border: 2px dashed var(--zinc-border);
  }

  @media (max-width: 480px) {
    .docs-hub {
      padding: 5rem 1rem 3rem;
    }

    .doc-card {
      padding: 1rem;
      gap: 1rem;
    }

    .doc-card-title {
      font-size: 1rem;
    }

    .doc-card-desc {
      font-size: 0.75rem;
    }

    .doc-card-icon {
      width: 2.75rem;
      height: 2.75rem;
    }
  }

  @media (min-width: 640px) {
    .docs-hub-controls {
      flex-direction: row;
      align-items: center;
    }

    .docs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .docs-hub-header {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }
  }
</style>
