---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import VisualDiagram from '../components/sections/VisualDiagram.astro';
import LogoGrid from '../components/sections/LogoGrid.astro';
import ProblemAnalysis from '../components/sections/ProblemAnalysis.astro';
import Metaphor from '../components/sections/Metaphor.astro';
import FeaturesGrid from '../components/sections/FeaturesGrid.astro';

const lang = 'es';
---

<Layout lang={lang}>
  <Navbar lang={lang} />
  <Hero lang={lang} />
  <VisualDiagram lang={lang} />
  <LogoGrid />
  <ProblemAnalysis lang={lang} />
  <Metaphor lang={lang} />
  <FeaturesGrid lang={lang} />
  <Footer lang={lang} />
</Layout>
